<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportHeight="108"
    android:viewportWidth="108">

    <!-- Deep Glow Base -->
    <path
        android:pathData="M54,15 L60,48 L93,54 L60,60 L54,93 L48,60 L15,54 L48,48 Z"
        android:fillColor="#2EDBFF"
        android:alpha="0.15" />

    <!-- Main 8-Pointed Star (The Risen Emblem) -->
    <path
        android:pathData="M54,18 L59,49 L90,54 L59,59 L54,90 L49,59 L18,54 L49,49 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="18"
                android:startY="18"
                android:endX="90"
                android:endY="90">
                <item android:offset="0.0" android:color="#FFFFFF" />
                <item android:offset="0.5" android:color="#2EDBFF" /> <!-- RISEN Primary Blue -->
                <item android:offset="1.0" android:color="#0088AA" /> <!-- Darker Brand Blue -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Compass Detail -->
    <path
        android:pathData="M54,32 L56,52 L76,54 L56,56 L54,76 L52,56 L32,54 L52,52 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="32"
                android:startY="32"
                android:endX="76"
                android:endY="76">
                <item android:offset="0.0" android:color="#FFFFFF" /> <!-- Pure Shine -->
                <item android:offset="1.0" android:color="#2EDBFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Center Cognitive Core -->
    <path
        android:pathData="M54,54m-5,0a5,5 0,1 1,10 0a5,5 0,1 1,-10 0"
        android:fillColor="#FFFFFF" />

</vector>
